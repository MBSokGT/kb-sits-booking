# Node server
HOST=0.0.0.0
PORT=3000
DB_FILE=./data/kb-sits.sqlite
BODY_LIMIT=10mb

# Security/CORS
# Example: https://kb.example.ru,https://admin.example.ru
CORS_ORIGINS=https://your-domain.example
# Force cookie Secure flag: 1=true, 0=false, empty=auto by request scheme
AUTH_COOKIE_SECURE=

# Optional: LDAP / Active Directory auth (0=off, 1=on)
LDAP_ENABLED=0
LDAP_URL=ldaps://dc1.company.local:636
LDAP_BASE_DN=DC=company,DC=local
LDAP_BIND_DN=CN=svc_kb_booking,OU=Service Accounts,DC=company,DC=local
# IMPORTANT (docker compose): escape '$' as '$$' in this value
LDAP_BIND_PASSWORD=
LDAP_USER_FILTER=(|(sAMAccountName={{login}})(userPrincipalName={{login}})(mail={{login}}))
LDAP_ROLE_ADMIN_GROUP_DN=CN=KB-Booking-Admins,OU=Groups,DC=company,DC=local
LDAP_ROLE_MANAGER_GROUP_DN=CN=KB-Booking-Managers,OU=Groups,DC=company,DC=local
LDAP_DEFAULT_DEPARTMENT=Домен
LDAP_FALLBACK_EMAIL_DOMAIN=company.local
LDAP_TLS_REJECT_UNAUTHORIZED=1
LDAP_TIMEOUT_MS=5000
LDAP_CONNECT_TIMEOUT_MS=5000

# Optional: create/update admin on each start
BOOTSTRAP_ADMIN_EMAIL=admin@your-domain.example
BOOTSTRAP_ADMIN_PASSWORD=change_me_very_strong
BOOTSTRAP_ADMIN_NAME=Главный администратор
BOOTSTRAP_ADMIN_DEPARTMENT=Администрация

# Optional: local backups (used by scripts/backup-sqlite.sh + systemd timer)
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=730

# Optional: auto-update (used by scripts/auto-update.sh + systemd timer)
AUTO_UPDATE_BRANCH=main
AUTO_UPDATE_GIT_REMOTE=origin
AUTO_UPDATE_MODE=node
AUTO_UPDATE_SERVICE_NAME=kb-sits
AUTO_UPDATE_HEALTH_URL=http://127.0.0.1:3000/api/health
AUTO_UPDATE_HEALTH_TIMEOUT=120
