# Node server
HOST=0.0.0.0
PORT=3000
DB_FILE=./data/kb-sits.sqlite
BODY_LIMIT=10mb

# Security/CORS
# Example: https://kb.example.ru,https://admin.example.ru
CORS_ORIGINS=https://your-domain.example

# Optional: create/update admin on each start
BOOTSTRAP_ADMIN_EMAIL=admin@your-domain.example
BOOTSTRAP_ADMIN_PASSWORD=change_me_very_strong
BOOTSTRAP_ADMIN_NAME=Главный администратор
BOOTSTRAP_ADMIN_DEPARTMENT=Администрация
