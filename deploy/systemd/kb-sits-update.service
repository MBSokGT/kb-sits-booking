[Unit]
Description=KB Sits auto update from Git
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/opt/kb-sits-booking
EnvironmentFile=/opt/kb-sits-booking/.env
ExecStart=/opt/kb-sits-booking/scripts/auto-update.sh
User=root
Group=root
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/opt/kb-sits-booking

